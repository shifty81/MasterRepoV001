{
  "project": {
    "name": "NovaForge",
    "type": "standalone-game-repo",
    "version": "0.1.0-reset",
    "defaultWorld": "DevWorld",
    "defaultStartupMode": "Editor"
  },
  "paths": {
    "contentRoot": "Content",
    "configRoot": "Config",
    "saveRoot": "Saved",
    "logRoot": "Saved/Logs",
    "data": "Content/Data",
    "schemas": "Schemas",
    "scripts": "Scripts"
  },
  "server": {
    "default_port": 27015,
    "tick_rate": 60,
    "max_players": 20,
    "protocol": "lockstep_rollback"
  },
  "game": {
    "deterministic_simulation": true
  },
  "phases": [
    "Phase0_Bootstrap",
    "Phase1_DevWorldOnly",
    "Phase2_VoxelRuntimeOnly",
    "Phase3_FirstInteractionLoopOnly"
  ],
  "rules": {
    "voxelAuthoritative": true,
    "editorShipsWithGame": false,
    "allowSuiteFeaturesInRepo": false
  }
}